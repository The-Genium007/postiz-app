# Configuration reference: http://docs.postiz.com/configuration/reference
#
# Pour Dokploy : ces variables sont configurables dans Dokploy > Environment.
# Pour le dev local : copier ce fichier en .env et remplir les valeurs.

# ==========================================================================
# REQUIRED
# ==========================================================================

# URL publique de Postiz (en Docker Compose prod, alimente MAIN_URL/FRONTEND_URL/NEXT_PUBLIC_BACKEND_URL)
POSTIZ_URL="http://localhost:5000"

# En dev local (sans Docker) :
FRONTEND_URL="http://localhost:4200"
NEXT_PUBLIC_BACKEND_URL="http://localhost:3000"
BACKEND_INTERNAL_URL="http://localhost:3000"

# Securite — generer avec : openssl rand -hex 32
JWT_SECRET=""

# Base de donnees
# En Docker Compose : construite depuis POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB
DATABASE_URL="postgresql://postiz-local:postiz-local-pwd@localhost:5432/postiz-db-local"
REDIS_URL="redis://localhost:6379"

# Variables du docker-compose pour PostgreSQL Postiz
POSTGRES_USER=""
POSTGRES_PASSWORD=""
POSTGRES_DB=""

# Variables du docker-compose pour PostgreSQL Temporal
TEMPORAL_DB_USER=""
TEMPORAL_DB_PASSWORD=""

# ==========================================================================
# STORAGE
# ==========================================================================

# "local" ou "cloudflare"
STORAGE_PROVIDER="local"
UPLOAD_DIRECTORY="/uploads"
NEXT_PUBLIC_UPLOAD_DIRECTORY="/uploads"
#NEXT_PUBLIC_UPLOAD_STATIC_DIRECTORY=""

# Si cloudflare :
#CLOUDFLARE_ACCOUNT_ID=""
#CLOUDFLARE_ACCESS_KEY=""
#CLOUDFLARE_SECRET_ACCESS_KEY=""
#CLOUDFLARE_BUCKETNAME=""
#CLOUDFLARE_BUCKET_URL=""
#CLOUDFLARE_REGION="auto"

# ==========================================================================
# EMAIL (optionnel)
# ==========================================================================
#RESEND_API_KEY=""
#EMAIL_FROM_ADDRESS=""
#EMAIL_FROM_NAME=""

# ==========================================================================
# SOCIAL MEDIA API KEYS
# ==========================================================================
X_API_KEY=""
X_API_SECRET=""
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
REDDIT_CLIENT_ID=""
REDDIT_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
THREADS_APP_ID=""
THREADS_APP_SECRET=""
YOUTUBE_CLIENT_ID=""
YOUTUBE_CLIENT_SECRET=""
TIKTOK_CLIENT_ID=""
TIKTOK_CLIENT_SECRET=""
PINTEREST_CLIENT_ID=""
PINTEREST_CLIENT_SECRET=""
DRIBBBLE_CLIENT_ID=""
DRIBBBLE_CLIENT_SECRET=""
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
DISCORD_BOT_TOKEN_ID=""
SLACK_ID=""
SLACK_SECRET=""
SLACK_SIGNING_SECRET=""
MASTODON_URL="https://mastodon.social"
MASTODON_CLIENT_ID=""
MASTODON_CLIENT_SECRET=""
BEEHIIVE_API_KEY=""
BEEHIIVE_PUBLICATION_ID=""
LISTMONK_DOMAIN=""
LISTMONK_USER=""
LISTMONK_API_KEY=""
LISTMONK_LIST_ID=""

# ==========================================================================
# EXTENSION CHROME
# ==========================================================================
EXTENSION_ID=""

# ==========================================================================
# MISC
# ==========================================================================
OPENAI_API_KEY=""
NEXT_PUBLIC_DISCORD_SUPPORT=""
NEXT_PUBLIC_POLOTNO=""
API_LIMIT=30
DISABLE_REGISTRATION=false

# ==========================================================================
# DEVELOPER SETTINGS
# ==========================================================================
NX_ADD_PLUGINS=false
IS_GENERAL="true"

# --- OAuth generique (optionnel) ---
#POSTIZ_GENERIC_OAUTH="false"
#NEXT_PUBLIC_POSTIZ_OAUTH_DISPLAY_NAME="Authentik"
#NEXT_PUBLIC_POSTIZ_OAUTH_LOGO_URL=""
#POSTIZ_OAUTH_URL=""
#POSTIZ_OAUTH_AUTH_URL=""
#POSTIZ_OAUTH_TOKEN_URL=""
#POSTIZ_OAUTH_USERINFO_URL=""
#POSTIZ_OAUTH_CLIENT_ID=""
#POSTIZ_OAUTH_CLIENT_SECRET=""
#POSTIZ_OAUTH_SCOPE="openid profile email"

